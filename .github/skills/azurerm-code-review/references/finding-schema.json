{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AzureRM Review Finding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "roles",
    "title",
    "scope",
    "severity",
    "evidence",
    "reasoning",
    "confidence",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "reviewer",
          "architect",
          "skeptic",
          "advocate"
        ]
      }
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "files"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "files": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "lines": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "severity": {
      "enum": [
        "critical",
        "high",
        "medium",
        "low",
        "observation"
      ]
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "value"
        ],
        "properties": {
          "kind": {
            "enum": [
              "diff",
              "file",
              "contributor-guide",
              "local-delta",
              "tool",
              "pattern",
              "external"
            ]
          },
          "value": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "reasoning": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "status": {
      "enum": [
        "candidate",
        "observation",
        "confirmed",
        "downgraded",
        "dismissed"
      ]
    },
    "ruleReferences": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "roleNotes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "summary"
        ],
        "properties": {
          "role": {
            "enum": [
              "reviewer",
              "architect",
              "skeptic",
              "advocate"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}